{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferry",
  "version": "../package.json",
  "identifier": "dev.kzheart.ferry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ferry",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://example.invalid/ferry-updater-placeholder/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaW5pIHB1YmxpYyBrZXk6IDVFNzFCNjg5OUFEOTBENUMKUldSY0RkbWFpYlp4WGhkZmlQVzE2SUVDalgrRjJCVzNmZ2taV3VCUG1zZ3RmaUNMN3JBblRGT3IK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "externalBin": ["binaries/ferry-engine"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
