{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferry",
  "version": "../package.json",
  "identifier": "dev.kzheart.ferry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Ferry",
        "width": 1120,
        "height": 760,
        "minWidth": 1000,
        "minHeight": 680,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kzheart/ferry/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaW5pIHB1YmxpYyBrZXk6IDNGNzQzRkFEQ0RDQUFEMDEKUldRQnJjck5yVDkwUDhydnZwWTY0Yk1ITHZKeHpZQS93WlhIeWgyaHJvVzBySEp2bjNKVXdLTXMK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "externalBin": ["binaries/ferry-engine"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
