{
  "name": "ferry",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:boundaries": "node ../scripts/check-frontend-boundaries.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.{js,ts}'",
